# =====================================================================
# VicinatoVicino — file di configurazione segreta. Copialo in `.env` e modifica.
#
# Tutto cio' che e' qui dentro NON deve finire in git.
# La config "non segreta" ma editabile (nome sito, logo, descrizione, ...)
# sta in config.yaml o nel pannello admin.
# =====================================================================

# Chiave per firmare i JWT. CAMBIALA in produzione (es. `openssl rand -hex 32`)
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# URL del database. Se LASCIATO COMMENTATO, viene usato il default di
# config.py: SQLite con path ASSOLUTO <repo>/vicinato.db (= stesso file
# usato prima della config esterna, cosi' non si perde il DB esistente).
# Sovrascrivi solo se vuoi un DB diverso (es. Postgres).
# Esempio Postgres: postgresql+psycopg2://user:pass@host:5432/vicinato
# DATABASE_URL=sqlite:////percorso/assoluto/vicinato.db

# Origini CORS ammesse (CSV). Usa "*" solo in dev.
CORS_ORIGINS=*

# Cartella upload. Default: <repo>/backend/uploads (path assoluto).
# Lascia commentato per usare il default; sovrascrivi solo se serve.
# UPLOADS_DIR=/percorso/assoluto/uploads

# Durata del token in minuti (default: 7 giorni)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# NOTA: al primo avvio, se non esiste alcun utente admin nel DB, viene
# creato automaticamente un account `admin` / `ChangeMe123!`.
# CAMBIA QUESTA PASSWORD SUBITO DOPO IL PRIMO LOGIN dal pannello profilo.
# Le credenziali vengono stampate nei log di uvicorn al boot.
